{
  "name": "@quentinroy/word-cloud",
  "private": false,
  "version": "0.6.0",
  "description": "Interactive word cloud custom element powered by Matter.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuentinRoy/word-cloud.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.lib.json",
    "build:demo": "vite build --mode demo",
    "preview": "vite preview --mode demo",
    "release": "pnpm run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^24.12.0",
    "arktype": "^2.2.0",
    "html-minifier-terser": "^7.2.0",
    "type-fest": "^5.5.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@quentinroy/custom-element-mixins": "npm:@jsr/quentinroy__custom-element-mixins@^0.4.1",
    "matter-js": "^0.20.0"
  }
}
